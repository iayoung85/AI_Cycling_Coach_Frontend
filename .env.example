# GitHub repo to read plan files from
VITE_GITHUB_OWNER=your-github-username
VITE_GITHUB_REPO=AI_Cycling_Coach
VITE_GITHUB_BRANCH=main

# Optional: add a token for higher API rate limits (60 req/hr anon vs 5000/hr authenticated)
# WARNING: VITE_ vars are bundled into client JS and are publicly visible.
# For a public read-only repo this is not needed.
# VITE_GITHUB_TOKEN=github_pat_xxxxx
